      "md": {
        "px": 20,
        "rem": "1.25rem",
        "usage": "Card headings, panel labels"
      },
      "lg": {
        "px": 24,
        "rem": "1.5rem",
        "usage": "Section subheadings, landing subtitle"
      },
      "xl": {
        "px": 32,
        "rem": "2rem",
