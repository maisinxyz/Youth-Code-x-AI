      "deliberate": {
        "ms": 450,
        "s": "0.45s",
        "usage": "Response card rise, drawer slide enter"
      },
      "slow": {
        "ms": 600,
        "s": "0.60s",
        "usage": "ChromaticAberration ease-back, drawer slide exit"
      },
      "cinematic": {
        "ms": 1200,
        "s": "1.2s",
        "usage": "Camera drift to activated cluster"
      },
      "emergence": {
        "ms": 3000,
        "s": "3.0s",
        "usage": "Full ingestion sequence minimum floor"
      }
    },

    "easing": {
      "easeOut": {
        "value": "cubic-bezier(0.0, 0.0, 0.2, 1.0)",
        "usage": "All enters — panels rising, cards appearing, nodes materializing"
      },
      "easeIn": {
        "value": "cubic-bezier(0.4, 0.0, 1.0, 1.0)",
        "usage": "All exits — panels dismissing, cards leaving"
      },
      "easeInOut": {
        "value": "cubic-bezier(0.4, 0.0, 0.2, 1.0)",
        "usage": "Camera drift, idle oscillation, sustained animations"
      },
      "sharp": {
        "value": "cubic-bezier(0.4, 0.0, 0.6, 1.0)",
        "usage": "Quick reversals, snappy feedback"
      },
      "overshoot": {
        "value": "cubic-bezier(0.34, 1.56, 0.64, 1.0)",
        "usage": "Node emergence overshoot (scale 0 → 1.2 → 1.0)"
      },
      "linear": {
        "value": "cubic-bezier(0.0, 0.0, 1.0, 1.0)",
        "usage": "Progress lines, continuous fills"
      }
    },

    "spring": {
      "nodeEmergence": {
        "mass": 1,
        "tension": 280,
        "friction": 60,
        "comment": "react-spring config for node materialization in Three.js"
      },
      "panelRise": {
        "mass": 1,
        "tension": 300,
        "friction": 50,
        "comment": "react-spring config for response card and floating panels"
      }
