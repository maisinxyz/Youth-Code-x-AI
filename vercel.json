{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "echo skip-root-install",
  "framework": null,
  "build": {
    "env": {
      "VITE_API_URL": "/api"
    }
  },
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.3.1",
      "includeFiles": "backend/app/**/*.py",
      "excludeFiles": "{frontend/**,node_modules/**,.git/**,backend/data/**,backend/tests/**,backend/.pytest_cache/**,**/__pycache__/**}"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/api", "destination": "/api/index" }
  ]
}
